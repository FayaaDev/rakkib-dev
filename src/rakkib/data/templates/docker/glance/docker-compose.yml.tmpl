services:
  glance:
    image: glanceapp/glance:latest
    container_name: glance
    restart: unless-stopped
    env_file: .env
    volumes:
      # Glance v0.7.0+ expects glance.yml at /app/config/glance.yml
      - {{DATA_ROOT}}/data/glance/glance.yml:/app/config/glance.yml:ro
    networks:
      - {{DOCKER_NET}}

networks:
  {{DOCKER_NET}}:
    external: true
