# Forgejo runtime user inside the container
USER_UID=1000
USER_GID=1000

# Web URL behind Caddy
{% if EXPOSURE_MODE == "cloudflare" %}
FORGEJO__server__DOMAIN={{FORGEJO_SUBDOMAIN}}.{{DOMAIN}}
FORGEJO__server__ROOT_URL=https://{{FORGEJO_SUBDOMAIN}}.{{DOMAIN}}/
{% else %}
FORGEJO__server__DOMAIN={{LAN_IP | default('127.0.0.1', true)}}
FORGEJO__server__ROOT_URL=http://{{LAN_IP | default('127.0.0.1', true)}}:13020/
{% endif %}
FORGEJO__server__PROTOCOL=http
FORGEJO__server__HTTP_PORT=3000

# Database (shared Rakkib postgres)
FORGEJO__database__DB_TYPE=postgres
FORGEJO__database__HOST=postgres:5432
FORGEJO__database__NAME=forgejo_db
FORGEJO__database__USER=forgejo
FORGEJO__database__PASSWD={{FORGEJO_DB_PASS}}

# Basic hardening defaults
FORGEJO__security__INSTALL_LOCK=true
FORGEJO__service__DISABLE_REGISTRATION=true
