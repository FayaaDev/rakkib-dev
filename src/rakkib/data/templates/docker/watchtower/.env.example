# Watchtower environment file
# Only containers explicitly enabled and scoped are updated.
# Add these labels to a container you want Watchtower to manage:
# - com.centurylinklabs.watchtower.enable=true
# - com.centurylinklabs.watchtower.scope=rakkib

WATCHTOWER_LABEL_ENABLE=true
WATCHTOWER_SCOPE=rakkib
WATCHTOWER_SCHEDULE=0 0 4 * * *
WATCHTOWER_CLEANUP=true
WATCHTOWER_NO_STARTUP_MESSAGE=true

# Force a modern Docker API version (some Watchtower builds default too low).
DOCKER_API_VERSION=1.54
