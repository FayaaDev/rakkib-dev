services:
  ollama-amd:
    image: ${OLLAMA_AMD_IMAGE:-ollama/ollama:rocm}
    container_name: ollama-amd
    restart: unless-stopped
    env_file:
      - .env
    ports:
      - "${OLLAMA_AMD_BIND_IP:-127.0.0.1}:${OLLAMA_AMD_HOST_PORT:-11434}:11434"
    devices:
      - /dev/kfd
      - /dev/dri
    group_add:
      - video
    volumes:
      - {{DATA_ROOT}}/data/ollama-amd:/root/.ollama
    networks:
      - {{DOCKER_NET}}

networks:
  {{DOCKER_NET}}:
    external: true
