# Note Mark configuration.
NOTEMARK_IMAGE=ghcr.io/enchant97/note-mark-aio:0.19.4

# Base URL where Note Mark is accessed. Upstream requires no trailing slash.
PUBLIC_URL=https://{{NOTEMARK_SUBDOMAIN}}.{{DOMAIN}}

# JWT signing secret. Keep stable after first deploy.
JWT_SECRET={{NOTEMARK_JWT_SECRET}}

# Enable first-user setup. Disable after creating users if you do not want open registration.
ENABLE_INTERNAL_SIGNUP=true
ENABLE_INTERNAL_LOGIN=true
