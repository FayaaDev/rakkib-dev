# Ollama (NVIDIA) environment file
#
# Requirements (host):
# - NVIDIA GPU + NVIDIA drivers.
# - NVIDIA Container Toolkit installed and configured for Docker.
#
# Notes:
# - Ollama is an API on port 11434 (no web UI). Rakkib does not expose it via Caddy.
# - The compose template binds the port to 127.0.0.1 by default (local-only).

OLLAMA_NVIDIA_IMAGE=ollama/ollama:latest
OLLAMA_NVIDIA_BIND_IP=127.0.0.1
OLLAMA_NVIDIA_HOST_PORT=11434
