# n8n Database Configuration
DB_TYPE=postgresdb
DB_POSTGRESDB_HOST=postgres
DB_POSTGRESDB_PORT=5432
DB_POSTGRESDB_DATABASE=n8n_db
DB_POSTGRESDB_USER=n8n
DB_POSTGRESDB_PASSWORD=n8n-db-pass

# n8n Instance Configuration

N8N_HOST=192.168.0.10
N8N_PROTOCOL=http
N8N_PORT=5678
WEBHOOK_URL=http://192.168.0.10:13004/

GENERIC_TIMEZONE=Asia/Riyadh
N8N_PROXY_HOPS=1

# n8n Encryption Key (CRITICAL - DO NOT CHANGE after first run or data will be lost)
N8N_ENCRYPTION_KEY=n8n-encryption-key-123456789012

# Security: Enable all nodes (remove default blocks)
