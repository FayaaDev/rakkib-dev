services:
  dockge:
    image: louislam/dockge:latest
    container_name: dockge
    restart: unless-stopped
    env_file:
      - .env
    volumes:
      - /var/run/docker.sock:/var/run/docker.sock
      - {{DATA_ROOT}}/data/dockge:/app/data
      - {{DATA_ROOT}}/docker:/opt/stacks
    networks:
      - {{DOCKER_NET}}
    healthcheck:
      # dockge image doesn't ship wget; use node's built-in fetch.
      test: ['CMD', 'node', '-e', "fetch('http://127.0.0.1:5001/').then(r=>process.exit(r.ok?0:1)).catch(()=>process.exit(1))"]
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 15s

networks:
  {{DOCKER_NET}}:
    external: true
