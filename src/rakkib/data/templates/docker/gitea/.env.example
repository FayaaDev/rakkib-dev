# Gitea runtime user inside the container
USER_UID=1000
USER_GID=1000

# Web URL behind Caddy
GITEA__server__DOMAIN={{GITEA_SUBDOMAIN}}.{{DOMAIN}}
GITEA__server__ROOT_URL=https://{{GITEA_SUBDOMAIN}}.{{DOMAIN}}/
GITEA__server__PROTOCOL=http
GITEA__server__HTTP_PORT=3000

# Database (shared Rakkib postgres)
GITEA__database__DB_TYPE=postgres
GITEA__database__HOST=postgres:5432
GITEA__database__NAME=gitea_db
GITEA__database__USER=gitea
GITEA__database__PASSWD={{GITEA_DB_PASS}}

# Basic hardening defaults
GITEA__security__INSTALL_LOCK=true
GITEA__service__DISABLE_REGISTRATION=true
