# Ollama (AMD ROCm) environment file
#
# Requirements (host):
# - AMD GPU + ROCm-capable drivers.
# - /dev/kfd and /dev/dri available on the host (this compose maps them into the container).
#
# Notes:
# - Ollama is an API on port 11434 (no web UI). Rakkib does not expose it via Caddy.
# - The compose template binds the port to 127.0.0.1 by default (local-only).

OLLAMA_AMD_IMAGE=ollama/ollama:rocm
OLLAMA_AMD_BIND_IP=127.0.0.1
OLLAMA_AMD_HOST_PORT=11434
