# Open WebUI environment file
OPEN_WEBUI_IMAGE=ghcr.io/open-webui/open-webui:main

# Ollama (default assumes Ollama runs on the host):
OLLAMA_BASE_URL=http://host.docker.internal:11434

# Optional: OpenAI API key if using OpenAI-compatible backends
#OPENAI_API_KEY=

# Optional but recommended: secret used to sign/encrypt sessions
#WEBUI_SECRET_KEY=
